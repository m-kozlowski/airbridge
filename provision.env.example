# AirBridge provisioning config
# Copy to provision.env and fill in your values.
# This file is read by provision.py after flashing.
#
# Key names match $CONFIG keys. Only set what you need.
# Lines starting with # are ignored. Empty values are skipped.

wifi_ssid=
wifi_pass=
wifi_mode=0

# http_user=admin
# http_pass=airbridge
# ota_password=airbridge
# oxi_device_addr=AA:BB:CC:DD:EE:FF
